rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function userDoc(uid) {
      return get(/databases/$(database)/documents/users/$(uid));
    }

    function currentUserData() {
      return userDoc(request.auth.uid).data;
    }

    function isActiveUser() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        currentUserData().isActive == true;
    }

    function isGoogleLinkedAccount() {
      return isActiveUser() &&
        ('googleEmail' in currentUserData()) &&
        currentUserData().googleEmail is string &&
        currentUserData().googleEmail.size() > 0;
    }

    function isOwner(userId) {
      return isActiveUser() && request.auth.uid == userId;
    }

    function isSelf(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function roleIs(role) {
      return isActiveUser() && currentUserData().role == role;
    }

    function isSuperAdmin() {
      return roleIs('superAdmin');
    }

    function isDoctor() {
      return roleIs('doctor');
    }

    function hasRolePermission(permissionKey) {
      return isGoogleLinkedAccount() &&
        (
          currentUserData().role == 'superAdmin' ||
          (
            currentUserData().role == 'admin' &&
            ('adminPermissions' in currentUserData()) &&
            currentUserData().adminPermissions[permissionKey] == true
          )
        );
    }

    function hasAnyRolePermission(keys) {
      return hasRolePermission(keys[0]) ||
        (keys.size() > 1 && hasRolePermission(keys[1])) ||
        (keys.size() > 2 && hasRolePermission(keys[2]));
    }

    function isDoctorForAppointment(doctorDocId) {
      return isDoctor() &&
        exists(/databases/$(database)/documents/doctors/$(doctorDocId)) &&
        get(/databases/$(database)/documents/doctors/$(doctorDocId)).data.isActive == true &&
        get(/databases/$(database)/documents/doctors/$(doctorDocId)).data.userId == request.auth.uid;
    }

    function hasDoctorPatientAccess(patientId) {
      return isDoctor() &&
        exists(/databases/$(database)/documents/doctor_patient_access/$(request.auth.uid)/patients/$(patientId));
    }

    function canReadAppointment(data) {
      return isOwner(data.patientId) ||
        isDoctorForAppointment(data.doctorId) ||
        hasAnyRolePermission(['appointments.view', 'analytics.view', 'reports.view']);
    }

    function canReadMedicalDocument(data) {
      return (isGoogleLinkedAccount() && request.auth.uid == data.userId) ||
        hasDoctorPatientAccess(data.userId) ||
        hasAnyRolePermission(['reports.view', 'appointments.view', 'analytics.view']);
    }

    match /users/{userId} {
      allow get: if isSelf(userId) ||
        hasRolePermission('users.view') ||
        isSuperAdmin() ||
        hasDoctorPatientAccess(userId);
      allow list: if hasRolePermission('users.view') ||
        isSuperAdmin();
      allow create: if false;
      allow update: if isOwner(userId) &&
        isGoogleLinkedAccount() &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'fullName',
          'phoneNumber',
          'photoUrl',
          'dateOfBirth',
          'bloodType',
          'allergies',
          'notificationSettings',
          'language',
          'themeMode',
          'updatedAt'
        ]) &&
        !request.resource.data.diff(resource.data).affectedKeys()
          .hasAny(['role', 'isActive', 'superAdminType', 'adminPermissions', 'fcmTokens', 'lastTokenUpdate']);
      allow delete: if false;
    }

    match /doctor_patient_access/{doctorUid}/patients/{patientId} {
      allow read: if isSuperAdmin();
      allow write: if false;
    }

    match /notifications/{notificationId} {
      allow read: if isGoogleLinkedAccount() && resource.data.userId == request.auth.uid;
      allow create: if false;
      allow update: if isGoogleLinkedAccount() &&
        resource.data.userId == request.auth.uid &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead']);
      allow delete: if isGoogleLinkedAccount() && resource.data.userId == request.auth.uid;
    }

    match /user_tokens/{userId} {
      allow read, write: if isOwner(userId) && isGoogleLinkedAccount();

      match /tokens/{tokenId} {
        allow read, write: if isOwner(userId) && isGoogleLinkedAccount();
      }
    }

    match /appointments/{appointmentId} {
      allow read: if isGoogleLinkedAccount() && canReadAppointment(resource.data);
      allow create, update, delete: if false;
    }

    match /doctor_availability_requests/{requestId} {
      allow read: if isGoogleLinkedAccount() &&
        (
          resource.data.doctorUserId == request.auth.uid ||
          hasRolePermission('doctors.manage')
        );
      allow create, update, delete: if false;
    }

    match /doctors/{doctorId} {
      allow read: if isGoogleLinkedAccount();
      allow update: if isGoogleLinkedAccount() &&
        resource.data.userId == request.auth.uid &&
        !request.resource.data.diff(resource.data).affectedKeys()
          .hasAny([
            'userId',
            'email',
            'isActive',
            'isAvailable',
            'availabilityRequestStatus',
            'pendingAvailabilityRequestId',
            'availabilityRequestReason',
            'availabilityRequestedAt',
            'lastUnavailableApprovedAt',
            'lastAvailabilityRequestId',
            'lastAvailabilityRequestReason',
            'availabilityUsageMonth'
          ]);
      allow create, delete: if false;
    }

    match /departments/{departmentId} {
      allow read: if true;
      allow write: if false;
    }

    match /admin_audit_logs/{logId} {
      allow read: if isSuperAdmin();
      allow write: if false;
    }

    match /medical_documents/{docId} {
      allow read: if isGoogleLinkedAccount() && canReadMedicalDocument(resource.data);
      allow create: if isGoogleLinkedAccount() &&
        request.resource.data.userId is string &&
        request.resource.data.addedBy == request.auth.uid &&
        request.resource.data.keys().hasOnly([
          'id',
          'userId',
          'name',
          'type',
          'notes',
          'fileName',
          'url',
          'storagePath',
          'uploadedAt',
          'updatedAt',
          'addedBy',
          'addedByRole',
          'addedByName',
          'appointmentId'
        ]) &&
        request.resource.data.keys().hasAll([
          'userId',
          'name',
          'type',
          'fileName',
          'url',
          'storagePath',
          'addedBy',
          'addedByRole'
        ]) &&
        request.resource.data.storagePath is string &&
        request.resource.data.storagePath.matches('medical_documents/' + request.resource.data.userId + '/[^/]+/[^/]+') &&
        (
          (request.resource.data.userId == request.auth.uid &&
            request.resource.data.addedByRole == 'patient') ||
          (request.resource.data.userId != request.auth.uid &&
            request.resource.data.addedByRole == 'doctor')
        ) &&
        (
          request.resource.data.userId == request.auth.uid ||
          hasDoctorPatientAccess(request.resource.data.userId)
        );
      allow update: if isGoogleLinkedAccount() &&
        canReadMedicalDocument(resource.data) &&
        resource.data.addedBy == request.auth.uid &&
        request.resource.data.userId == resource.data.userId &&
        request.resource.data.storagePath == resource.data.storagePath &&
        request.resource.data.url == resource.data.url &&
        request.resource.data.addedBy == resource.data.addedBy &&
        request.resource.data.addedByRole == resource.data.addedByRole &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'id',
          'name',
          'type',
          'notes',
          'updatedAt'
        ]);
      allow delete: if isGoogleLinkedAccount() &&
        canReadMedicalDocument(resource.data) &&
        resource.data.addedBy == request.auth.uid;
    }
  }
}

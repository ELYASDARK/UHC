rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper Functions ──
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isAuthenticated() && getUserRole() == 'admin';
    }

    function isSuperAdmin() {
      return isAuthenticated() && getUserRole() == 'superAdmin';
    }

    function isAdminOrSuperAdmin() {
      return isAuthenticated() &&
        (getUserRole() == 'admin' || getUserRole() == 'superAdmin');
    }

    // Resolves a doctor's Firestore doc ID → auth UID via the userId field.
    // appointment.doctorId stores DoctorModel.id (Firestore doc ID),
    // NOT DoctorModel.userId (auth UID), so we must look it up.
    function isDoctorForAppointment(doctorDocId) {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/doctors/$(doctorDocId)).data.userId == request.auth.uid;
    }

    // Check if the authenticated user has the 'doctor' role in the users collection.
    function isDoctor() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'doctor';
    }

    // ── Users Collection ──
    // Owner can update profile-safe fields only.
    // Sensitive fields (role, isActive, superAdminType, adminPermissions)
    // can only be changed via Cloud Functions (Admin SDK bypasses rules).
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if false; // Only Cloud Functions create users
      allow update: if isOwner(userId) &&
        // Block client-side changes to sensitive governance fields
        !request.resource.data.diff(resource.data).affectedKeys()
          .hasAny(['role', 'isActive', 'superAdminType', 'adminPermissions']);
      allow delete: if false; // Only Cloud Functions delete users
    }

    // ── Notifications Collection ──
    match /notifications/{notificationId} {
      allow read: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;
    }

    // ── User Tokens for FCM ──
    match /user_tokens/{userId} {
      allow read, write: if isOwner(userId);
    }

    // ── Appointments Collection ──
    // Both patient and doctor can update (status changes, medical notes).
    // doctorId stores the doctor's Firestore doc ID, not auth UID,
    // so we resolve via get() on the doctors collection.
    match /appointments/{appointmentId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() &&
        (resource.data.patientId == request.auth.uid ||
         isDoctorForAppointment(resource.data.doctorId));
      allow delete: if isAuthenticated() &&
        (resource.data.patientId == request.auth.uid ||
         isDoctorForAppointment(resource.data.doctorId));
    }

    // ── Doctors Collection ──
    // Anyone authenticated can read doctor profiles.
    // Only the doctor themselves can update their own profile.
    // Create/delete handled by Cloud Functions (Admin SDK bypasses rules).
    match /doctors/{doctorId} {
      allow read: if isAuthenticated();
      allow update: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;
      allow create, delete: if isAdminOrSuperAdmin();
    }

    // ── Departments Collection ──
    // Public read; admin/superAdmin write.
    match /departments/{departmentId} {
      allow read: if true;
      allow write: if isAdminOrSuperAdmin();
    }

    // ── Admin Audit Logs ──
    // Read: Super Admin only (admins cannot see governance logs).
    // Write: denied from client — only Cloud Functions write audit logs.
    match /admin_audit_logs/{logId} {
      allow read: if isSuperAdmin();
      allow write: if false;
    }

    // ── Medical Documents Collection ──
    // Read: patient reads own docs, doctor reads any.
    // Create: patient creates own docs, doctor creates with addedBy == self.
    // Update/Delete: only docs you personally added (addedBy == auth.uid).
    // Backward compat: old docs without addedBy fall back to userId check.
    match /medical_documents/{docId} {
      allow read: if isAuthenticated() &&
        (resource.data.userId == request.auth.uid || isDoctor());
      allow create: if isAuthenticated() &&
        (request.resource.data.userId == request.auth.uid ||
         (isDoctor() && request.resource.data.addedBy == request.auth.uid));
      allow update, delete: if isAuthenticated() &&
        (resource.data.addedBy == request.auth.uid ||
         (!('addedBy' in resource.data) && resource.data.userId == request.auth.uid));
    }
  }
}

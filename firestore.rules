rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function userDoc(uid) {
      return get(/databases/$(database)/documents/users/$(uid));
    }

    function currentUserData() {
      return userDoc(request.auth.uid).data;
    }

    function isActiveUser() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        currentUserData().isActive == true;
    }

    function isOwner(userId) {
      return isActiveUser() && request.auth.uid == userId;
    }

    function roleIs(role) {
      return isActiveUser() && currentUserData().role == role;
    }

    function isSuperAdmin() {
      return roleIs('superAdmin');
    }

    function isDoctor() {
      return roleIs('doctor');
    }

    function hasRolePermission(permissionKey) {
      return isActiveUser() &&
        (
          currentUserData().role == 'superAdmin' ||
          (
            currentUserData().role == 'admin' &&
            ('adminPermissions' in currentUserData()) &&
            currentUserData().adminPermissions[permissionKey] == true
          )
        );
    }

    function hasAnyRolePermission(keys) {
      return hasRolePermission(keys[0]) ||
        (keys.size() > 1 && hasRolePermission(keys[1])) ||
        (keys.size() > 2 && hasRolePermission(keys[2]));
    }

    function isDoctorForAppointment(doctorDocId) {
      return isDoctor() &&
        exists(/databases/$(database)/documents/doctors/$(doctorDocId)) &&
        get(/databases/$(database)/documents/doctors/$(doctorDocId)).data.isActive == true &&
        get(/databases/$(database)/documents/doctors/$(doctorDocId)).data.userId == request.auth.uid;
    }

    function hasDoctorPatientAccess(patientId) {
      return isDoctor() &&
        exists(/databases/$(database)/documents/doctor_patient_access/$(request.auth.uid)/patients/$(patientId));
    }

    function canReadAppointment(data) {
      return isOwner(data.patientId) ||
        isDoctorForAppointment(data.doctorId) ||
        hasAnyRolePermission(['appointments.view', 'analytics.view', 'reports.view']);
    }

    function canReadMedicalDocument(data) {
      return isOwner(data.userId) ||
        hasDoctorPatientAccess(data.userId) ||
        hasAnyRolePermission(['reports.view', 'appointments.view', 'analytics.view']);
    }

    match /users/{userId} {
      allow get, list: if isOwner(userId) ||
        hasRolePermission('users.view') ||
        isSuperAdmin() ||
        hasDoctorPatientAccess(userId);
      allow create: if isAuthenticated() &&
        request.auth.uid == userId &&
        request.resource.data.role == 'student' &&
        request.resource.data.isActive == true;
      allow update: if isOwner(userId) &&
        !request.resource.data.diff(resource.data).affectedKeys()
          .hasAny(['role', 'isActive', 'superAdminType', 'adminPermissions', 'fcmTokens', 'lastTokenUpdate']);
      allow delete: if false;
    }

    match /doctor_patient_access/{doctorUid}/patients/{patientId} {
      allow read: if isSuperAdmin();
      allow write: if false;
    }

    match /notifications/{notificationId} {
      allow read: if isActiveUser() && resource.data.userId == request.auth.uid;
      allow create: if false;
      allow update: if isActiveUser() &&
        resource.data.userId == request.auth.uid &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead']);
      allow delete: if isActiveUser() && resource.data.userId == request.auth.uid;
    }

    match /user_tokens/{userId} {
      allow read, write: if isOwner(userId);
    }

    match /appointments/{appointmentId} {
      allow read: if isActiveUser() && canReadAppointment(resource.data);
      allow create, update, delete: if false;
    }

    match /doctors/{doctorId} {
      allow read: if isActiveUser();
      allow update: if isActiveUser() &&
        resource.data.userId == request.auth.uid &&
        !request.resource.data.diff(resource.data).affectedKeys()
          .hasAny(['userId', 'email', 'isActive']);
      allow create, delete: if false;
    }

    match /departments/{departmentId} {
      allow read: if true;
      allow write: if false;
    }

    match /admin_audit_logs/{logId} {
      allow read: if isSuperAdmin();
      allow write: if false;
    }

    match /medical_documents/{docId} {
      allow read: if isActiveUser() && canReadMedicalDocument(resource.data);
      allow create: if isActiveUser() &&
        request.resource.data.userId is string &&
        request.resource.data.addedBy == request.auth.uid &&
        (
          request.resource.data.userId == request.auth.uid ||
          hasDoctorPatientAccess(request.resource.data.userId)
        );
      allow update, delete: if isActiveUser() &&
        canReadMedicalDocument(resource.data) &&
        resource.data.addedBy == request.auth.uid;
    }
  }
}
